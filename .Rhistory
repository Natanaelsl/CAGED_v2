)
return(df_final)
# ----------------------------------------
# 🟡 REGRA: TABELA 7 (e 7.1)
# ----------------------------------------
} else if (str_detect(nome_aba, "Tabela 7")) {
indice_corte <- which(df[[1]] == "Não identificado")[1]
